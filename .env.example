# ============================================================================
# ${ORG_REPO_NAME} .env.example
# ============================================================================
# This file is a TEMPLATE. The init wizard (`pnpm init`) will:
#   - Substitute ${...} placeholders with values you provide.
#   - Copy the result to `runtime/secrets/.env.local`.
#   - Pre-fill identity-related vars (ORG_NAME, FOUNDER_*, SUPABASE_OPS_*).
# You then manually add the remaining secrets (LLM keys, Stripe, etc.).
#
# Copy to runtime/secrets/.env.local manually if not using the wizard.
# NEVER commit the actual .env.local file (only this template).
#
# 3 LLM Access Modes (see playbook chương 30 for full explanation):
#   1. SUBSCRIPTION-ONLY: Leave ANTHROPIC_API_KEY and OPENAI_API_KEY empty.
#      Use Claude Pro/Max via Claude Code only. ~50% Phase A.2 features.
#      Cost: $20-100/mo (subscription only).
#
#   2. HYBRID (RECOMMENDED v1.0): Fill in selective API keys.
#      Autonomous skills selectively enabled via knowledge/feature-flags.yaml.
#      Cost: $45-65/mo.
#
#   3. FULL API (v1.5+): All API keys + all feature flags enabled.
#      Cost: $160-300/mo.
# ============================================================================

# === Deployment Mode (Bước A or B) ===
# local: workers run on this laptop (Bước A)
# production: this is the VPS (Bước B)
AGENT_OS_DEPLOYMENT_MODE=local

# === Workers location ===
# local: pnpm workers run here
# vps:   workers on remote VPS (Bước B)
AGENT_OS_WORKERS_LOCATION=local

# === Telegram bot location ===
# local: bot runs here when laptop on
# vps:   bot 24/7 on VPS (Bước B)
# disabled: not running
AGENT_OS_TELEGRAM_BOT_LOCATION=disabled

# === MCP Server mode ===
# stdio: Claude Code direct subprocess (default Bước A)
# http:  HTTP server (mcp.${PRODUCT_DOMAIN} for Bước B)
AGENT_OS_MCP_SERVER_MODE=stdio
AGENT_OS_MCP_HTTP_PORT=3001
AGENT_OS_MCP_HTTP_URL=http://localhost:3001
# AGENT_OS_MCP_HTTP_URL=https://mcp.${PRODUCT_DOMAIN}      # uncomment for Bước B

# ============================================================================
# Supabase (REQUIRED — Wave 1)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=eyJhbGc...        # for server-side migrations + admin

# ============================================================================
# LLM Providers
# ============================================================================
# 
# SUBSCRIPTION-ONLY MODE: Leave both empty.
# All LLM work happens in Claude Code session manually.
#
# HYBRID MODE: Fill in for autonomous high-leverage skills.
#   - Anthropic: morning brief, pre-call dossier, voice classification
#   - OpenAI: Whisper transcription, embeddings
#
# FULL API MODE: Fill in + set mode: full_api in feature-flags.yaml.
#

# Anthropic API (autonomous Claude calls — for hybrid + full_api modes)
ANTHROPIC_API_KEY=
# Get from: https://console.anthropic.com/

# OpenAI API (Whisper + embeddings — for hybrid + full_api modes)
OPENAI_API_KEY=
# Get from: https://platform.openai.com/

# ============================================================================
# Telegram (Wave 2-3, Bài #6 sub-domain B + Bài #17 surface)
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_FOUNDER_CHAT_ID=               # founder Telegram user ID
TELEGRAM_BOT_USERNAME=

# ============================================================================
# Email (Wave 6, Bài #17 surface)
# ============================================================================
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_INGEST_ADDRESS=ingest@${PRIMARY_EMAIL_DOMAIN}

# ============================================================================
# Stripe (Wave 5+, Bài #16 customer + Bài #11 webhook events)
# ============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ============================================================================
# GitHub (Bài #11 events + auto-deploy Phase B)
# ============================================================================
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ============================================================================
# Runtime config
# ============================================================================
AGENT_OS_ENV=development                    # development | staging | production
AGENT_OS_LOG_LEVEL=info                     # debug | info | warn | error
AGENT_OS_LOCALE_DEFAULT=vi                  # primary locale (Bài #17)
AGENT_OS_DATA_REGION=eu                     # eu | us | apac (Bài #16)
AGENT_OS_TIMEZONE=${FOUNDER_TIMEZONE}

# ============================================================================
# Cost limits (Bài #7 economic unit)
# ============================================================================
AGENT_OS_DAILY_BUDGET_USD=10
AGENT_OS_DAILY_WHISPER_MINUTES_MAX=60
AGENT_OS_DAILY_LLM_TOKENS_MAX=1000000

# ============================================================================
# Multi-surface APIs (Bài #17, Wave 6+)
# ============================================================================
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_BEARER_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
WHATSAPP_BUSINESS_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ============================================================================
# VPS deployment (Bước B trigger)
# ============================================================================
DEPLOY_VPS_HOST=
DEPLOY_VPS_USER=${ORG_SLUG}
DEPLOY_BRANCH=main

# ============================================================================
# Optional: external services
# ============================================================================
SENTRY_DSN=                              # error tracking
POSTHOG_API_KEY=                         # analytics (privacy-respectful)
