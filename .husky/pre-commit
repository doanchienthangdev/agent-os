#!/bin/sh
# husky v9: no longer sources _/husky.sh (removed in v10).

# Reject if runtime files staged (except runtime/README.md)
RUNTIME_FILES=$(git diff --cached --name-only | grep -E "^runtime/" | grep -v "^runtime/README.md$" || true)
if [ -n "$RUNTIME_FILES" ]; then
  echo "❌ ERROR: Attempting to commit runtime data!"
  echo ""
  echo "Files staged in runtime/:"
  echo "$RUNTIME_FILES"
  echo ""
  echo "If this is a genuine commit (e.g., updating runtime/README.md),"
  echo "review carefully. Otherwise, unstage with:"
  echo "  git reset HEAD runtime/"
  exit 1
fi

# Reject if .env files staged (except .env.example)
ENV_FILES=$(git diff --cached --name-only | grep -E "^\.env" | grep -v "^\.env\.example$" | grep -v "^\.env\.template$" || true)
if [ -n "$ENV_FILES" ]; then
  echo "❌ ERROR: Attempting to commit .env file!"
  echo ""
  echo "Files staged:"
  echo "$ENV_FILES"
  echo ""
  echo "Unstage with: git reset HEAD .env*"
  exit 1
fi

# Detect potential secret patterns in diff
SECRET_PATTERN=$(git diff --cached -U0 | grep -iE "(api[_-]?key|secret|password|token|bearer)\s*[:=]\s*['\"]?[a-zA-Z0-9]{20,}" 2>/dev/null || true)
if [ -n "$SECRET_PATTERN" ]; then
  echo "⚠️  WARNING: Potential secret detected in diff!"
  echo ""
  echo "Review carefully before committing:"
  echo "$SECRET_PATTERN" | head -5
  echo ""
  echo "If false positive, commit with --no-verify (use sparingly)"
  exit 1
fi

# Check for committed .DS_Store, etc.
JUNK_FILES=$(git diff --cached --name-only | grep -E "(\.DS_Store|Thumbs\.db|desktop\.ini)$" || true)
if [ -n "$JUNK_FILES" ]; then
  echo "⚠️  WARNING: OS junk files staged:"
  echo "$JUNK_FILES"
  echo ""
  echo "Add to .gitignore or unstage with: git reset HEAD <file>"
  exit 1
fi

# Run linter on staged files (if configured)
if command -v pnpm >/dev/null 2>&1 && [ -f package.json ] && grep -q '"lint-staged"' package.json; then
  pnpm lint-staged
fi

# ──────────────────────────────────────────────────────────────────────────
# Cross-Tier Consistency Engine — L1 checks
# (knowledge/cross-tier-invariants.yaml)
# ──────────────────────────────────────────────────────────────────────────

# If schedules.yaml staged, regenerate bundle and add to commit.
if git diff --cached --name-only | grep -q '^knowledge/schedules\.yaml$'; then
  if [ -f scripts/wave2-bundle-schedules.cjs ]; then
    node scripts/wave2-bundle-schedules.cjs >/dev/null
    git add supabase/functions/_shared/schedules.generated.ts
  fi
fi

# If cross-tier-invariants.yaml staged, regenerate the invariants bundle.
if git diff --cached --name-only | grep -q '^knowledge/cross-tier-invariants\.yaml$'; then
  if [ -f scripts/wave2-bundle-invariants.cjs ]; then
    node scripts/wave2-bundle-invariants.cjs >/dev/null
    git add supabase/functions/_shared/invariants.generated.ts
  fi
fi

# If manifest.yaml staged, regenerate the manifest-tables bundle.
if git diff --cached --name-only | grep -q '^knowledge/manifest\.yaml$'; then
  if [ -f scripts/wave2-bundle-manifest-tables.cjs ]; then
    node scripts/wave2-bundle-manifest-tables.cjs >/dev/null
    git add supabase/functions/_shared/manifest-tables.generated.ts
  fi
fi

# Tier 1 YAML schema validation (~1s)
if [ -f scripts/validate-tier1.cjs ]; then
  if ! node scripts/validate-tier1.cjs >/dev/null 2>&1; then
    echo "❌ Tier 1 schema validation failed."
    echo "   Run for details: node scripts/validate-tier1.cjs"
    exit 1
  fi
fi

# Cross-tier critical validators (~2s total). Warn-tier ones (governance-roles,
# hitl-hooks) intentionally skipped at pre-commit — they run in CI as
# continue-on-error.
for V in validate-manifest-db.cjs validate-skills-references.cjs validate-schedules-skills.cjs; do
  if [ -f "scripts/cross-tier/$V" ]; then
    if ! node "scripts/cross-tier/$V" >/dev/null 2>&1; then
      echo "❌ Cross-tier check failed: $V"
      echo "   Run for details: node scripts/cross-tier/$V"
      echo "   Override with --no-verify only if you understand the drift."
      exit 1
    fi
  fi
done

exit 0
