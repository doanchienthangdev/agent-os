{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "workforce-personas.schema.json",
  "title": "Workforce Persona Registry",
  "description": "Schema for knowledge/workforce-personas.yaml — the persona → role binding registry. See .archives/workforces/00-architecture-decisions/ADR-003-mapping-csuite-to-roles.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "last_updated", "owner", "current_phase", "personas"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "owner": {
      "type": "string"
    },
    "current_phase": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "personas": {
      "type": "object",
      "patternProperties": {
        "^[a-z]{3,5}$": {
          "$ref": "#/$defs/persona"
        }
      },
      "additionalProperties": false
    },
    "not_in_roster": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "rationale"],
        "properties": {
          "slug": { "type": "string" },
          "rationale": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "naming_policy": {
      "type": "object",
      "properties": {
        "slug_pattern": { "type": "string" },
        "slash_command_pattern": { "type": "string" },
        "mention_pattern": { "type": "string" },
        "no_prefix": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "persona": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "full_name",
        "phase",
        "status",
        "pillar_home",
        "binds_to",
        "invocations",
        "voice_profile",
        "default_hitl_max"
      ],
      "properties": {
        "full_name": { "type": "string" },
        "phase": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "status": {
          "type": "string",
          "enum": ["active", "planned", "deferred", "retired"]
        },
        "pillar_home": {
          "type": "string",
          "pattern": "^06-ai-ops/workforce-personas/[a-z]{3,5}/$"
        },
        "binds_to": {
          "type": "object",
          "required": ["primary"],
          "additionalProperties": false,
          "properties": {
            "primary": { "type": "string" },
            "contextual": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "invocations": {
          "type": "object",
          "required": ["slash_command", "subagent_mention"],
          "additionalProperties": false,
          "properties": {
            "slash_command": {
              "type": "string",
              "pattern": "^/[a-z]{3,5}$"
            },
            "subagent_mention": {
              "type": "string",
              "pattern": "^@[a-z]{3,5}$"
            }
          }
        },
        "routing_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z]{3,5}$"
          }
        },
        "voice_profile": {
          "type": "string"
        },
        "default_hitl_max": {
          "type": "string",
          "enum": ["A", "B", "C", "D-Std", "D-MAX"]
        },
        "notify_founder": {
          "type": "boolean"
        },
        "escalation_bypass_ceo": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        },
        "spec_dir": {
          "type": "string"
        },
        "activation_trigger": {
          "type": "string"
        },
        "deferred_rationale": {
          "type": "string"
        },
        "blocking_dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
