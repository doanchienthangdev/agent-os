{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "alert-rules.schema.json",
  "title": "Alert Rules (Bài #10)",
  "type": "object",
  "required": ["version", "rules"],
  "properties": {
    "version": {"type": "string"},
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "condition", "severity", "notify"],
        "properties": {
          "id": {"type": "string"},
          "condition": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "warning", "critical"]},
          "notify": {"type": "array", "items": {"type": "string"}},
          "suppress_for": {"type": "string"}
        }
      }
    }
  }
}
