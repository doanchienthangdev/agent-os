{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event-subscriptions.schema.json",
  "title": "Event Subscriptions (B\u00e0i #11)",
  "type": "object",
  "required": [
    "version",
    "subscriptions"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "subscriptions": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "required": [
          "event",
          "trigger"
        ],
        "properties": {
          "event": {
            "type": "string"
          },
          "trigger": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "enum": [
              "tier_a",
              "tier_b",
              "tier_c",
              "tier_d",
              "tier_e"
            ]
          },
          "filter": {
            "type": "object"
          }
        }
      }
    }
  }
}