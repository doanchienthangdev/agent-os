{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schedules.schema.json",
  "title": "Schedules Configuration",
  "description": "Tier 1 declarative file for scheduled triggers (Bài #8)",
  "type": "object",
  "required": ["version", "timezone", "schedules"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone (e.g., '${FOUNDER_TIMEZONE}')"
    },
    "schedules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "cron", "skill"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
          "cron": {"type": "string"},
          "description": {"type": "string"},
          "skill": {"type": "string"},
          "enabled_when_mode": {
            "type": "array",
            "items": {"type": "string", "enum": ["subscription", "hybrid", "full_api"]}
          },
          "requires_api": {"type": "string", "enum": ["anthropic", "openai", "supabase_product_read"]},
          "fallback": {"type": "string"},
          "cost_estimate": {"type": "string"}
        }
      }
    }
  }
}
