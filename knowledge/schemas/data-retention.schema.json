{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "data-retention.schema.json",
  "title": "Data Retention Policies (Bài #16)",
  "type": "object",
  "required": ["version", "retention_policies"],
  "properties": {
    "version": {"type": "string"},
    "retention_policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["data_type", "retention_period", "legal_basis"],
        "properties": {
          "data_type": {"type": "string"},
          "retention_period": {"type": "string"},
          "legal_basis": {"type": "string", "enum": ["consent", "contract", "legal_obligation", "vital_interest", "public_task", "legitimate_interest"]},
          "deletion_method": {"type": "string", "enum": ["soft_delete", "hard_delete", "anonymize"]}
        }
      }
    }
  }
}
