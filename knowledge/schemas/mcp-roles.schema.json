{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mcp-roles.schema.json",
  "title": "MCP Role Definitions (Bài #12)",
  "type": "object",
  "required": ["version", "roles"],
  "properties": {
    "version": {"type": "string"},
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "tool_pattern"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "tool_pattern": {"type": "string"}
        }
      }
    }
  }
}
