{
  "name": "agent-os",
  "version": "0.1.0",
  "description": "Agent-OS boilerplate — substrate for AI-native organizations.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "init": "node scripts/init.cjs",
    "validate": "node scripts/validate-tier1.cjs",
    "validate:tier1": "node scripts/validate-tier1.cjs",
    "lint:yaml": "node scripts/validate-tier1.cjs",
    "check": "node scripts/check-consistency.cjs",
    "check:full": "node scripts/check-consistency.cjs --full",
    "check:remote": "node scripts/check-consistency.cjs --remote",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset --debug",
    "wave2:bundle-schedules": "node scripts/wave2-bundle-schedules.cjs",
    "wave2:bundle-invariants": "node scripts/wave2-bundle-invariants.cjs",
    "wave2:bundle-manifest-tables": "node scripts/wave2-bundle-manifest-tables.cjs",
    "bootstrap": "bash .scripts/bootstrap.sh"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.12.0",
    "husky": "^9.0.0",
    "js-yaml": "^4.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "license": "UNLICENSED"
}
